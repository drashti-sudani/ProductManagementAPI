    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=DRASHTI;Initial Catalog=CRNProductManagement;Integrated Security=True;Encrypt=False"
  },
  "JwtSettings": {
    "Secret": "3c9f8a2b6d4e1f7a9b2c3d4e5f6071829a0b1c2d3e4f5061728394a5b6c7d8e9",
